<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Toggle -->
        <androidx.cardview.widget.CardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="8dp" app:cardElevation="2dp">
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:orientation="horizontal" android:background="@color/grey_light" android:padding="4dp">
                <Button android:id="@+id/btn_peru_tipo" android:layout_width="wrap_content" android:layout_height="40dp"
                    android:text="Perú" android:textSize="12sp" android:textStyle="bold"
                    android:backgroundTint="@color/navy_dark" android:textColor="@color/white"
                    style="?attr/materialButtonStyle" />
                <Button android:id="@+id/btn_ext_tipo" android:layout_width="wrap_content" android:layout_height="40dp"
                    android:text="Extranjero" android:textSize="12sp" android:textStyle="bold"
                    android:backgroundTint="@android:color/transparent" android:textColor="@color/grey_text"
                    style="?attr/materialButtonStyle" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Composición Votos -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp" app:cardElevation="3dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Composición de Votos" android:textColor="@color/navy_dark"
                    android:textSize="14sp" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Distribución porcentual total" android:textColor="@color/grey_text" android:textSize="11sp" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginTop="14dp" android:gravity="center_vertical">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="Votos Válidos" android:textColor="@color/navy_dark" android:textSize="11sp" android:textStyle="bold" />
                    <TextView android:id="@+id/tv_pct_validos_tipo" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="93.512%" android:textColor="@color/navy_dark" android:textSize="11sp" android:textStyle="bold" />
                </LinearLayout>
                <ProgressBar android:id="@+id/prog_validos_tipo" android:layout_width="match_parent" android:layout_height="8dp"
                    android:layout_marginTop="4dp" android:progress="93" android:max="100"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:progressTint="@color/navy_dark" android:progressBackgroundTint="@color/grey_light" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginTop="12dp" android:gravity="center_vertical">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="Nulos" android:textColor="@color/navy_dark" android:textSize="11sp" android:textStyle="bold" />
                    <TextView android:id="@+id/tv_pct_nulos_tipo" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="5.673%" android:textColor="@color/navy_dark" android:textSize="11sp" android:textStyle="bold" />
                </LinearLayout>
                <ProgressBar android:id="@+id/prog_nulos_tipo" android:layout_width="match_parent" android:layout_height="8dp"
                    android:layout_marginTop="4dp" android:progress="5" android:max="100"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:progressTint="@color/grey_text" android:progressBackgroundTint="@color/grey_light" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginTop="12dp" android:gravity="center_vertical">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="Blancos" android:textColor="@color/navy_dark" android:textSize="11sp" android:textStyle="bold" />
                    <TextView android:id="@+id/tv_pct_blancos_tipo" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0.815%" android:textColor="@color/navy_dark" android:textSize="11sp" android:textStyle="bold" />
                </LinearLayout>
                <ProgressBar android:id="@+id/prog_blancos_tipo" android:layout_width="match_parent" android:layout_height="8dp"
                    android:layout_marginTop="4dp" android:progress="1" android:max="100"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:progressTint="@color/grey_border" android:progressBackgroundTint="@color/grey_light" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Card votos válidos oscuro -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp" app:cardBackgroundColor="@color/navy_dark" app:cardElevation="3dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="✓  Votos Válidos" android:textColor="@color/white"
                    android:textSize="14sp" android:textStyle="bold" />
                <TextView android:id="@+id/tv_num_validos_tipo" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="17,152,817" android:textColor="@color/white"
                    android:textSize="30sp" android:textStyle="bold" android:layout_marginTop="10dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Total nacional reportado" android:textColor="@color/grey_text" android:textSize="11sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Blancos y Nulos -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="12dp">
            <androidx.cardview.widget.CardView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_marginEnd="6dp"
                app:cardCornerRadius="12dp" app:cardElevation="3dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="14dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Blancos" android:textColor="@color/grey_text" android:textSize="9sp" android:textStyle="bold" />
                    <TextView android:id="@+id/tv_num_blancos_tipo" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="149,577" android:textColor="@color/navy_dark" android:textSize="16sp" android:textStyle="bold" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
            <androidx.cardview.widget.CardView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_marginStart="6dp"
                app:cardCornerRadius="12dp" app:cardElevation="3dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="14dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Nulos" android:textColor="@color/grey_text" android:textSize="9sp" android:textStyle="bold" />
                    <TextView android:id="@+id/tv_num_nulos_tipo" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="1,040,502" android:textColor="@color/navy_dark" android:textSize="16sp" android:textStyle="bold" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- Total emitidos -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp" app:cardElevation="3dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:text="TOTAL VOTOS EMITIDOS" android:textColor="@color/grey_text"
                    android:textSize="10sp" android:textStyle="bold" />
                <TextView android:id="@+id/tv_total_emitidos_tipo" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="18,342,896" android:textColor="@color/navy_dark"
                    android:textSize="18sp" android:textStyle="bold" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
