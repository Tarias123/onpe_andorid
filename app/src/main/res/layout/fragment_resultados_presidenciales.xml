<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ACTUALIZADO EL 20/06/2016 A LAS 19:16 H"
            android:textColor="@color/grey_text"
            android:textSize="10sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <!-- Toggle -->
        <androidx.cardview.widget.CardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@color/grey_light"
                android:padding="4dp">
                <Button
                    android:id="@+id/btn_peru_pres"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="Perú"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:backgroundTint="@color/navy_dark"
                    android:textColor="@color/white"
                    style="?attr/materialButtonStyle" />
                <Button
                    android:id="@+id/btn_ext_pres"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="Extranjero"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:backgroundTint="@android:color/transparent"
                    android:textColor="@color/grey_text"
                    style="?attr/materialButtonStyle" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- RecyclerView candidatos -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_candidatos_pres"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:layout_marginBottom="12dp" />

        <!-- Card escrutinio oscuro -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="@color/navy_dark"
            app:cardElevation="3dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AVANCE DE ESCRUTINIO"
                    android:textColor="@color/grey_text"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:orientation="vertical" android:gravity="center">
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="TOTAL" android:textColor="@color/grey_text" android:textSize="7sp"
                            android:gravity="center" android:maxLines="1" />
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="ACTAS" android:textColor="@color/grey_text" android:textSize="7sp"
                            android:gravity="center" android:maxLines="1" />
                        <TextView android:id="@+id/tv_total_actas_pres" android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="77,307" android:textColor="@color/white" android:textSize="11sp" android:textStyle="bold"
                            android:gravity="center" android:maxLines="1" />
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="100%" android:textColor="@color/gold" android:textSize="10sp" android:textStyle="bold"
                            android:gravity="center" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:orientation="vertical" android:gravity="center">
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="ACTAS" android:textColor="@color/grey_text" android:textSize="7sp"
                            android:gravity="center" android:maxLines="1" />
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="PROCESADAS" android:textColor="@color/grey_text" android:textSize="7sp"
                            android:gravity="center" android:maxLines="1" />
                        <TextView android:id="@+id/tv_procesadas_pres" android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="77,307" android:textColor="@color/white" android:textSize="11sp" android:textStyle="bold"
                            android:gravity="center" android:maxLines="1" />
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="100%" android:textColor="@color/gold" android:textSize="10sp" android:textStyle="bold"
                            android:gravity="center" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:orientation="vertical" android:gravity="center">
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="ACTAS" android:textColor="@color/grey_text" android:textSize="7sp"
                            android:gravity="center" android:maxLines="1" />
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="CONTABILIZ." android:textColor="@color/grey_text" android:textSize="7sp"
                            android:gravity="center" android:maxLines="1" />
                        <TextView android:id="@+id/tv_contabilizadas_pres" android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="77,307" android:textColor="@color/white" android:textSize="11sp" android:textStyle="bold"
                            android:gravity="center" android:maxLines="1" />
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="100%" android:textColor="@color/gold" android:textSize="10sp" android:textStyle="bold"
                            android:gravity="center" />
                    </LinearLayout>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#2D4070" android:layout_marginVertical="12dp" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="PARTICIPACIÓN CIUDADANA" android:textColor="@color/grey_text"
                    android:textSize="10sp" android:textStyle="bold" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginTop="10dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="ELECTORES HÁBILES" android:textColor="@color/grey_text" android:textSize="8sp"
                            android:maxLines="1" android:ellipsize="end" />
                        <TextView android:id="@+id/tv_electores_pres" android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="22,901,954" android:textColor="@color/white" android:textStyle="bold"
                            android:maxLines="1" android:ellipsize="end" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:orientation="vertical" android:gravity="end">
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="PARTICIPANTES" android:textColor="@color/grey_text" android:textSize="8sp"
                            android:gravity="end" android:maxLines="1" android:ellipsize="end" />
                        <TextView android:id="@+id/tv_participantes_pres" android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="18,342,896" android:textColor="@color/white" android:textStyle="bold"
                            android:gravity="end" android:maxLines="1" android:ellipsize="end" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginTop="12dp"
                    android:gravity="center_vertical">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="PORCENTAJE FINAL" android:textColor="@color/grey_text" android:textSize="10sp" />
                    <TextView android:id="@+id/tv_pct_pres" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="80.093%" android:textColor="@color/gold" android:textSize="24sp" android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Grid votos 2x2 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="12dp">
            <androidx.cardview.widget.CardView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_marginEnd="6dp"
                app:cardCornerRadius="12dp" app:cardElevation="3dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="12dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Votos Válidos" android:textColor="@color/grey_text" android:textSize="9sp" android:textStyle="bold" />
                    <TextView android:id="@+id/tv_validos_pres" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="17,152,817" android:textColor="@color/navy_dark" android:textSize="14sp" android:textStyle="bold" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
            <androidx.cardview.widget.CardView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_marginStart="6dp"
                app:cardCornerRadius="12dp" app:cardElevation="3dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="12dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Votos Blancos" android:textColor="@color/grey_text" android:textSize="9sp" android:textStyle="bold" />
                    <TextView android:id="@+id/tv_blancos_pres" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="149,577" android:textColor="@color/grey_text" android:textSize="14sp" android:textStyle="bold" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="12dp">
            <androidx.cardview.widget.CardView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_marginEnd="6dp"
                app:cardCornerRadius="12dp" app:cardElevation="3dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="12dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Votos Nulos" android:textColor="@color/grey_text" android:textSize="9sp" android:textStyle="bold" />
                    <TextView android:id="@+id/tv_nulos_pres" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="1,040,502" android:textColor="@color/grey_text" android:textSize="14sp" android:textStyle="bold" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
            <androidx.cardview.widget.CardView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_marginStart="6dp"
                app:cardCornerRadius="12dp" app:cardElevation="3dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="12dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Total Emitidos" android:textColor="@color/grey_text" android:textSize="9sp" android:textStyle="bold" />
                    <TextView android:id="@+id/tv_emitidos_pres" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="18,342,896" android:textColor="@color/grey_text" android:textSize="14sp" android:textStyle="bold" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
