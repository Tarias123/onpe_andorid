<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header actualización -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ACTUALIZADO EL 20/06/2016 A LAS 19:16 H"
            android:textColor="@color/grey_text"
            android:textSize="10sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <!-- Toggle Nacional / Extranjero -->
        <androidx.cardview.widget.CardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@color/grey_light"
                android:padding="4dp">
                <Button
                    android:id="@+id/btn_nacional_part"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="Nacional"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:backgroundTint="@color/navy_dark"
                    android:textColor="@color/white"
                    style="?attr/materialButtonStyle" />
                <Button
                    android:id="@+id/btn_extranjero_part"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="Extranjero"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:backgroundTint="@android:color/transparent"
                    android:textColor="@color/grey_text"
                    style="?attr/materialButtonStyle" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Card porcentaje grande oscuro -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="@color/navy_dark"
            app:cardElevation="3dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PARTICIPACIÓN CIUDADANA"
                    android:textColor="@color/grey_text"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/tv_pct_part"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="80.093%"
                    android:textColor="@color/gold"
                    android:textSize="48sp"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp" />

                <ProgressBar
                    android:id="@+id/prog_participacion"
                    android:layout_width="match_parent"
                    android:layout_height="10dp"
                    android:layout_marginTop="12dp"
                    android:progress="80"
                    android:max="100"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:progressTint="@color/gold"
                    android:progressBackgroundTint="#2D4070" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="16dp">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="ELECTORES HÁBILES"
                            android:textColor="@color/grey_text"
                            android:maxLines="1" android:ellipsize="end"
                            android:textSize="9sp" />
                        <TextView
                            android:id="@+id/tv_electores_part"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="22,901,954"
                            android:textColor="@color/white"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:maxLines="1" android:ellipsize="end" />
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="end">
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="PARTICIPANTES"
                            android:textColor="@color/grey_text"
                            android:textSize="9sp"
                            android:gravity="end"
                            android:maxLines="1" android:ellipsize="end" />
                        <TextView
                            android:id="@+id/tv_participantes_part"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="18,342,896"
                            android:textColor="@color/white"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:gravity="end"
                            android:maxLines="1" android:ellipsize="end" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Ausentismo card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ausentismo"
                    android:textColor="@color/navy_dark"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ciudadanos que no votaron"
                            android:textColor="@color/grey_text"
                            android:textSize="11sp" />
                        <TextView
                            android:id="@+id/tv_ausentismo_part"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="4,559,058"
                            android:textColor="@color/navy_dark"
                            android:textSize="20sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                    <TextView
                        android:id="@+id/tv_pct_ausentismo_part"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="19.907%"
                        android:textColor="@color/grey_text"
                        android:textSize="22sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Notas legales -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Notas"
                    android:textColor="@color/navy_dark"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="• El porcentaje de participación se calcula sobre el total de electores hábiles inscritos en el padrón electoral."
                    android:textColor="@color/grey_text"
                    android:textSize="11sp"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="• Los datos corresponden al cómputo oficial de la segunda vuelta presidencial 2016."
                    android:textColor="@color/grey_text"
                    android:textSize="11sp"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="• Fuente: Oficina Nacional de Procesos Electorales (ONPE)"
                    android:textColor="@color/grey_text"
                    android:textSize="11sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
